@using ApplicationLayer.ViewModels
@model MaintenanceViewModel

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Управление на училищен инвентар</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="fas fa-school me-2"></i>Управление на училищен инвентар</a>
        </div>
    </nav>
<div class="page" id="maintenanceView">
    <div class="form-container">
        <h2 id="maintenanceTitle">Добавяне на поддръжка</h2>
        <hr />

        <form asp-action="AddMaintenance" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="ParentId" />

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Устройство</label>
                        <input type="text" class="form-control" asp-for="ItemName" readonly>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Дата *</label>
                        <input class="form-control" asp-for="Date" type="date" />
                        <span asp-validation-for="Date" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Описание *</label>
                        <textarea class="form-control" asp-for="Description" rows="6"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                    <a class="btn btn-custom" asp-action="Details" asp-route-id="@Model.ParentId">
                    <i class="fas fa-arrow-left me-2"></i>Назад
                </a>

                <button type="submit" class="btn btn-custom">
                    <i class="fas fa-save me-2"></i>Запази
                </button>
            </div>
        </form>
    </div>
</div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
