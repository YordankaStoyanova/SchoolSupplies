@using ApplicationLayer.ViewModels
@using Microsoft.AspNetCore.Mvc.Rendering
@model HardwareViewModel

@{
    var softwareList = ViewBag.SoftwareList as SelectList;
    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Управление на училищен инвентар</title>
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="fas fa-school me-2"></i>Управление на училищен инвентар</a>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <div class="form-container">
            <h2>Редактиране на хардуер</h2>
            <hr />

            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="InventoryNumber" class="form-label">Инвентарен номер *</label>
                            <input asp-for="InventoryNumber" class="form-control" />
                            <span asp-validation-for="InventoryNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="SerialNumber" class="form-label">Сериен номер *</label>
                            <input asp-for="SerialNumber" class="form-control" />
                            <span asp-validation-for="SerialNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Име *</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TypeId" class="form-label">Вид *</label>
                            <select asp-for="TypeId" class="form-select" asp-items="ViewBag.Types as SelectList">
                                <option value="">Изберете вид</option>
                            </select>
                            <span asp-validation-for="TypeId" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label asp-for="RoomId" class="form-label">Локация *</label>
                            <select asp-for="RoomId" class="form-select" asp-items="ViewBag.Rooms as SelectList">
                                <option value="">Изберете локация</option>
                            </select>
                            <span asp-validation-for="RoomId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label">Статус *</label>
                            <select asp-for="Status" class="form-select">
                                <option value="">Изберете статус</option>
                                <option value="Working">Работещ</option>
                                <option value="Repair">За ремонт</option>
                                <option value="Disposed">Бракуван</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Инсталиран софтуер</label>
                            <select asp-for="SoftwareIds" class="form-select" multiple asp-items="softwareList"></select>
                            <small class="text-muted">Ctrl за повече от един</small>
                        </div>

                       
                    </div>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a class="btn btn-custom" asp-area="Identity" asp-page="/Account/Manage/Hardware">
                        <i class="fas fa-arrow-left me-2"></i> Назад
                    </a>
                    <button type="submit" class="btn btn-custom">
                        <i class="fas fa-save me-2"></i> Запази
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>