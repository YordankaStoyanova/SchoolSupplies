@using BusinessLayer
@model Hardware
@{
   
    var installedSoftware = ViewBag.InstalledSoftware as List<string> ?? new List<string>();
    Layout = null;
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Управление на училищен инвентар</title>
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        @@media (max-width:548px) {
            .btn-add-maintenance {
                margin-top: 15px !important;
            }
        }
        @@media (max-width:345px) {
            .btn-delete {
                margin-top: 15px;
            }
        }

        @@media screen and (min-width: 345px) and (max-width: 348px) {
            .btn-delete {
                margin-top: 15px;
            }
        }

    
      
       
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="fas fa-school me-2"></i>Управление на училищен инвентар</a>
        </div>
    </nav>
<div class="details-container">
    <div class="details-header">
        <div class="d-flex justify-content-between align-items-center">
            <h2 class="details-title">Детайли за хардуер</h2>
            
            <a class="btn btn-custom" asp-area="Identity" asp-page="/Account/Manage/Hardware">
                <i class="fas fa-arrow-left me-2"></i> Назад
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="info-section">
                <h5 class="info-label">Основна информация</h5>
                <div class="info-value">Инвентарен номер: @Model.InventoryNumber</div>
                <div class="info-value">Сериен номер: @Model.SerialNumber</div>
                <div class="info-value">Име: @Model.Name</div>
                <div class="info-value">Вид: @Model.Type?.Name</div>
                <div class="info-value">Локация: @Model.Room?.Name</div>
                    <div class="info-value">Статус: @Html.DisplayFor(model => model.Status)</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="info-section">
                <h5 class="info-label">История на поддръжката</h5>

                        @if (Model.MaintenanceLogs != null && Model.MaintenanceLogs.Any())
                        {
                            foreach (var log in Model.MaintenanceLogs.OrderByDescending(l => l.Date))
                            {
                                <div class="info-value">
                                    @log.Date.ToLocalTime().ToString("dd.MM.yyyy HH:mm") - @log.Description
                                </div>
                            }
                        }
                        else
                        {
                            <div class="info-value">Няма история</div>
                        }
            </div>
            <div class="info-section">
                <h5 class="info-label">Инсталиран софтуер</h5>
                <ul class="software-list">
                    @if (installedSoftware.Any())
                    {
                        @foreach (var sw in installedSoftware)
                        {
                            <li>@sw</li>
                        }
                    }
                    else
                    {
                        <li>Няма инсталиран софтуер</li>
                    }
                </ul>
            </div>
        </div>
    </div>
        @if (User.IsInRole("Administrator"))
        {
            <div class="mt-4 pt-3 border-top">
                <div class="d-flex justify-content-between">

                    <div>
                        <a class="btn btn-warning me-2" asp-action="Edit" asp-route-id="@Model.Id">
                            <i class="fas fa-edit me-2"></i> Редактиране
                        </a>
                        <a class="btn btn-danger btn-delete" asp-action="Delete" asp-route-id="@Model.Id">
                            <i class="fas fa-trash-alt me-2"></i> Изтриване
                        </a>
                        <a class="btn btn-maintenance btn-add-maintenance" asp-action="AddMaintenance" asp-route-id="@Model.Id">
                            <i class="fas fa-tools me-2"></i> Добави поддръжка
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</body>
</html>