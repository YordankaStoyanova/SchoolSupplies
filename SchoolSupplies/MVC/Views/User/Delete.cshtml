@using BusinessLayer
@model User
@{
    ViewData["Title"] = "Изтриване на потребител";
}

<div class="details-container">
    <div class="details-header">
        <h2 class="details-title">Изтриване на потребител</h2>
    </div>

    <div class="alert alert-warning" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>
        Сигурни ли сте, че искате да изтриете този потребител? Това действие е необратимо.
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="info-section">
                <h5 class="info-label">Потребител</h5>
                <div class="info-value"><strong>Име:</strong> @Model.Name</div>
                <div class="info-value"><strong>Имейл:</strong> @Model.Email</div>
                <div class="info-value"><strong>Телефонен номер:</strong> @Model.PhoneNumber</div>
            </div>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="d-flex justify-content-between">
            <a class="btn btn-secondary" asp-action="Index">
                <i class="fas fa-arrow-left me-2"></i>Назад
            </a>
            <button type="submit" class="btn btn-danger">
                <i class="fas fa-trash-alt me-2"></i>Изтрий
            </button>
        </div>
    </form>
</div>