@using BusinessLayer
@model User
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Управление на училищен инвентар</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <style>
        @@media (max-width:372px) {
            .btn-delete {
                margin-top: 15px;
            }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="fas fa-school me-2"></i>Управление на училищен инвентар</a>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <div class="details-container">
            <div class="details-header d-flex justify-content-between align-items-center">
                <h2 class="details-title">Детайли за потребител</h2>
                <a class="btn btn-custom" asp-area="Identity" asp-page="/Account/Manage/Administration">
                    <i class="fas fa-arrow-left me-2"></i> Назад
                </a>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="info-section">
                        <h5 class="info-label">Основна информация</h5>
                        <div class="info-value">Име: @Model.Name</div>
                        <div class="info-value">Имейл: @Model.Email</div>
                        <div class="info-value">Телефонен номер: @(Model.PhoneNumber ?? "не е посочен")</div>
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top">
                <div class="d-flex justify-content-between">
                    <div>
                        <a class="btn btn-warning me-2" asp-action="Edit" asp-route-id="@Model.Id">
                            <i class="fas fa-edit me-2"></i> Редактиране
                        </a>
                        <a class="btn btn-danger btn-delete" asp-action="Delete" asp-route-id="@Model.Id">
                            <i class="fas fa-trash-alt me-2"></i> Изтриване
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>