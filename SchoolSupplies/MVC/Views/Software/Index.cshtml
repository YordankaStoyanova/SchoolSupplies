@using BusinessLayer
@model List<Software>

@{
    ViewData["Title"] = "Software";
    var pageNumber = ViewBag.PageNumber ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;

    var currentSearch = Context.Request.Query["s"].ToString();
    var currentType = Context.Request.Query["t"].ToString();
    var currentRoom = Context.Request.Query["r"].ToString();
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Управление на училищен инвентар</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    </head>
<body>
<div class="tab-content">
    <div class="tab-pane fade show active">
        <div class="row">
            <div class="col-md-12">
                <div class="search-filter-container">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <div class="search-box">
                                <i class="fas fa-search"></i>
                                <form id="search">

                                    <input type="text" name="s" id="s" class="form-control" placeholder="Търсене по име на софтуер...">
                                </form>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <select class="form-select" id="t">
                                @*{
                                    var selectedType = ViewContext.RouteData.Values["t"]?.ToString();
                                    if (string.IsNullOrWhiteSpace(selectedType))
                                    {
                                        <option selected value="all">Всички видове</option>
                                        foreach (var item in Model.Select(s => s.Type).Distinct())
                                        {
                                            <option value="@item.Id">@item.Name</option>
                                        }
                                    }
                                    else
                                    {
                                        <option value="all">Всички видове</option>
                                        var type = int.Parse(selectedType);
                                        foreach (var item in Model.Select(s => s.Type).Distinct())
                                        {

                                            if (type == item.Id)
                                            {
                                                <option selected value="@item.Id">@item.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@item.Id">@item.Name</option>
                                            }
                                        }

                                    }
                                }*@
                                @{
                                    <option selected value="all">Всички видове</option>
                                    foreach (var item in Model.Select(s => s.Type).Distinct())
                                    {
                                        <option value="@item.Id">@item.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>

      
                <div class="table-container section-fixed-height">
                    <div class="table-responsive">
                        <table class="table table-custom table-hover">
                            <thead>
                                <tr>
                                    <th>Име</th>
                                    <th>Вид</th>
                                    <th>Статус на лиценза</th>
                                    <th>На устройства</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {

                                    var statusName = "";
                                    var statusBadge = "";

                                    if (item.License.ExpirationDate > DateTime.Now)
                                    {
                                        statusName = "Активен";
                                        statusBadge = "bg-success";
                                    }
                                    else
                                    {
                                        statusName = "Изтекъл";
                                        statusBadge = "bg-danger";
                                    }
                                    <tr>
                                        <td>@item.Name</td>
                                       <td>@item.Type.Name</td> 
                                        <td> <span class="badge @statusBadge ">@statusName</span></td>
                                        <td>
                                            @if (item.Hardwares != null && item.Hardwares.Any())
                                            {
                                                @string.Join(", ", item.Hardwares.Take(2).Select(h => h.Name))
                                                @(item.Hardwares.Count > 2 ? " и още..." : "")
                                            }
                                            else
                                            {
                                                <span>Няма устройства</span>
                                            } 
                                            @* @string.Join(", ", item.Hardwares.Take(2).Select(h => h.Name).ToList()) @(item.Hardwares?.Count > 2 ? "и още" : "") *@
                                            </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (totalPages > 1)
                    {
                        <div class="pagination-container">
                            @{
                                var prevDisabled = pageNumber <= 1 ? "disabled" : "";
                                var nextDisabled = pageNumber >= totalPages ? "disabled" : "";
                            }

                            <a class="btn btn-sm btn-outline-brown @prevDisabled"
                               asp-action="Index"
                               asp-route-pageNumber="@(pageNumber - 1)"
                               asp-route-s="@currentSearch"
                               asp-route-t="@currentType">
                                <i class="fas fa-chevron-left"></i>
                            </a>

                            @for (int i = 1; i <= totalPages; i++)
                            {
                                if (i == pageNumber)
                                {
                                    <button class="btn btn-sm btn-custom" disabled>@i</button>
                                }
                                else
                                {
                                    <a class="btn btn-sm btn-outline-brown"
                                       asp-action="Index"
                                       asp-route-pageNumber="@i"
                                       asp-route-s="@currentSearch"
                                       asp-route-t="@currentType">
                                        @i
                                    </a>
                                }
                            }

                            <a class="btn btn-sm btn-outline-brown @nextDisabled"
                               asp-action="Index"
                               asp-route-pageNumber="@(pageNumber + 1)"
                               asp-route-s="@currentSearch"
                               asp-route-t="@currentType">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
    </body>
    </html>
@section Scripts {
    <style>
        .badge-custom {
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
        }

        .pagination-container {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            gap: 5px;
            flex-wrap: wrap;
        }

            .pagination-container .btn {
                min-width: 40px;
            }

        .btn-outline-brown {
            color: var(--dark-brown);
            border: 1px solid var(--accent-brown);
            background-color: transparent;
            transition: all 0.3s;
        }

            .btn-outline-brown:hover:not(:disabled) {
                background-color: var(--accent-brown);
                color: white;
            }

            .btn-outline-brown:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

    </style>
    <script src="~/js/site.js" asp-append-version="true"></script>
}

  