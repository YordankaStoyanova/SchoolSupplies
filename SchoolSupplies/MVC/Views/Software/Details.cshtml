@using BusinessLayer
@model Software
@{

    Layout = null;

    var isActive = Model.License != null && Model.License.ExpirationDate > DateTime.Now;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Управление на училищен инвентар</title>
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>

        .btn-maintenance {
            background-color: #3498db;
            color: white;
        }

            .btn-maintenance:hover {
                background-color: #2980b9;
            }
        .btn-license {
            background-color: #90EE90;
            color: #333;
        }

            .btn-license:hover {
                background-color: #7CCD7C;
                color: #333;
            }

        @@media (max-width:371.5px) {
            .btn-delete {
                margin-top: 15px;
            }
        }

        @@media (max-width:470px) {
            .btn-add-license {
                margin-top: 15px;
            }
        }
         @@media screen and (min-width: 472px) and (max-width: 575px) {
                        .btn-add-license {
                            margin-top: 0px;
                        }
                    }

        @@media screen and (min-width: 577px) and (max-width: 763px) {
            .btn-add-license {
                margin-top: 15px;
            }
        }
        @@media (min-width: 577px) and (max-width: 763px) {
            .btn-add-license

        {
            margin-top: 15px !important;
        }

        }
        @@media (min-width:472px) {
            .btn-add-license {
                margin-top: 0px;
            }
        }
        @@media (max-width:576px) {
            .btn-add-maintenance{
            margin-top: 15px;
            margin-bottom: 15px;
        }
           
        }
        </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-school me-2"></i>Управление на училищен инвентар
            </a>
        </div>
    </nav>

    <div class="container-fluid mt-4">

        <div class="details-container">

            <div class="details-header">
                <div class="d-flex justify-content-between align-items-center">

                    <h2 class="details-title">Детайли за софтуер</h2>

                    <a class="btn btn-custom" asp-area="Identity" asp-page="/Account/Manage/Software">
                        <i class="fas fa-arrow-left me-2"></i>Назад
                    </a>

                </div>
            </div>

            <div class="row">

                <div class="col-md-6">

                    <div class="info-section">
                        <h5 class="info-label">Основна информация</h5>

                        <div class="info-value">Име: @Model.Name</div>
                        <div class="info-value">Сериен номер: @Model.SerialNumber</div>
                        <div class="info-value">Вид: @Model.Type?.Name</div>

                    </div>

                    <div class="info-section">
                        <h5 class="info-label">Лиценз</h5>

                        <div class="info-value">Име: @(Model.License?.Name ?? "Няма")</div>

                        <div class="info-value">
                            Валиден до:
                            @(Model.License != null ? Model.License.ExpirationDate.ToString("dd.MM.yyyy") : "Няма")
                        </div>

                        <div class="info-value">
                            Статус:
                            @(isActive ? "Активен" : "Изтекъл")
                        </div>

                    </div>

                    <div class="info-section">
                        <h5 class="info-label">Употреба</h5>

                        <div class="info-value">
                            Текуща употреба: @(Model.License?.Usage ?? 0)
                        </div>

                        <div class="info-value">
                            Максимална употреба: @(Model.License?.MaxUsage ?? 0)
                        </div>

                    </div>

                </div>


                <div class="col-md-6">

                    <div class="info-section">

                        <h5 class="info-label">История на поддръжката</h5>

                        @if (Model.MaintenanceLogs != null && Model.MaintenanceLogs.Any())
                        {
                            foreach (var log in Model.MaintenanceLogs.OrderByDescending(x => x.Date))
                            {
                                <div class="info-value">
                                    @log.Date.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    - @log.Description
                                </div>
                            }
                        }
                        else
                        {
                            <div class="info-value">Няма история</div>
                        }

                    </div>


                    <div class="info-section">

                        <h5 class="info-label">Инсталиран на компютри</h5>

                        <ul class="software-list">

                            @if (Model.Hardwares != null && Model.Hardwares.Any())
                            {
                                foreach (var hw in Model.Hardwares)
                                {
                                    <li>@hw.Name</li>
                                }
                            }
                            else
                            {
                                <li>Няма инсталации</li>
                            }

                        </ul>

                    </div>

                </div>

            </div>


            @if (User.IsInRole("Administrator"))
            {

                <div class="mt-4 pt-3 border-top">

                    <a class="btn btn-warning me-2" asp-action="Edit" asp-route-id="@Model.Id">
                        <i class="fas fa-edit me-2"></i>Редактиране
                    </a>

                    <a class="btn btn-danger me-2 btn-delete" asp-action="Delete" asp-route-id="@Model.Id">
                        <i class="fas fa-trash-alt me-2"></i>Изтриване
                    </a>

                    <a class="btn btn-maintenance me-2 btn-add-maintenance" asp-action="AddMaintenance" asp-route-id="@Model.Id">
                        <i class="fas fa-tools me-2"></i>Добави поддръжка
                    </a>
                    <a class="btn btn-license btn-add-license" asp-controller="Software" asp-action="License">
                        <i class="fas fa-key me-2"></i> Добави лиценз
                    </a>
                 

                </div>

            }

        </div>

    </div>

</body>
</html>