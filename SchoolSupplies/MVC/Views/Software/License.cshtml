@using BusinessLayer

@model License
@{
    ViewData["Title"] = "Добавяне на лиценз";
    var statusList = ViewBag.StatusList as SelectList; // Очаква се да бъде подаден от контролера
    Layout = null;
}

<div class="form-container">
    <h2>Добавяне на нов лиценз</h2>
    <hr />

    <form asp-controller="License" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="row">
            <!-- Лява колона -->
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Име на лиценза</label>
                    <input asp-for="Name" class="form-control" placeholder="Например: MIT License" />
                </div>
                <div class="mb-3">
                    <label asp-for="ExpirationDate" class="form-label">Валидност до </label>
                    <input asp-for="ExpirationDate" type="date" class="form-control" required />
                </div>
            </div>

            <!-- Дясна колона -->
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="MaxUsage" class="form-label">Максимална употреба</label>
                    <input asp-for="MaxUsage" type="number" min="0" value="0" class="form-control" />
                </div>
                
            </div>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a class="btn btn-secondary" asp-controller="Software" asp-action="Index">
                <i class="fas fa-arrow-left me-2"></i>Назад
            </a>
            <button type="submit" class="btn btn-license">
                <i class="fas fa-save me-2"></i>Запази лиценз
            </button>
        </div>
    </form>
</div>