@using BusinessLayer
@model Software
@{

    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Управление на училищен инвентар</title>
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/"><i class="fas fa-school me-2"></i>Управление на училищен инвентар</a>
        </div>
    </nav>

    <div class="container-fluid mt-4">
        <div class="details-container">
            <div class="details-header">
                <h2 class="details-title">Изтриване на софтуер</h2>
            </div>

            <h5>Сигурни ли сте, че искате да изтриете този софтуер?</h5>

            <div class="row mt-4">
                <div class="col-md-6">
                    <div class="info-section">
                        <div class="info-label">Име</div>
                        <div class="info-value">@Model.Name</div>

                        <div class="info-label">Сериен номер</div>
                        <div class="info-value">@Model.SerialNumber</div>

                        <div class="info-label">Вид</div>
                        <div class="info-value">@Model.Type?.Name</div>

                        <div class="info-label">Лиценз</div>
                        <div class="info-value">@(Model.License?.Name ?? "Няма")</div>

                        <div class="info-label">Статус</div>
                        <div class="info-value">
                            @(Model.License != null && Model.License.ExpirationDate > DateTime.Now ? "Активен" : "Изтекъл")
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-between">
                    <a class="btn btn-custom" asp-area="Identity" asp-page="/Account/Manage/Software">
                        <i class="fas fa-arrow-left me-2"></i> Назад
                    </a>

                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash-alt me-2"></i>Изтрий
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>