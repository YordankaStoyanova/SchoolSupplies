@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Забравена парола";
}

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <style>

        body {
            background-color: var(--primary-beige);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 0;
        }
        :root {
            --primary-beige: #F5F1E8;
            --secondary-cream: #E8DFCA;
            --accent-brown: #A68B7B;
            --dark-brown: #7D6E5D;
            --light-beige: #FAF7F0;
        }

        .forgot-password-container {
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }

        .forgot-password-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px 30px;
        }

        .forgot-password-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .forgot-password-header i {
                font-size: 3rem;
                color: var(--accent-brown);
                margin-bottom: 15px;
            }

        .btn-custom {
            background-color: var(--accent-brown);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s;
            width: 100%;
        }

            .btn-custom:hover {
                background-color: var(--dark-brown);
                color: white;
                transform: translateY(-2px);
            }

        .form-control {
            padding: 12px 15px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

            .form-control:focus {
                border-color: var(--accent-brown);
                box-shadow: 0 0 0 0.25rem rgba(166, 139, 123, 0.25);
            }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: var(--dark-brown);
            text-decoration: none;
            font-weight: 500;
        }

            .back-home:hover {
                color: var(--accent-brown);
            }

        .alert {
            border-radius: 8px;
        }

        .email-sent-message {
            text-align: center;
            padding: 20px;
        }

            .email-sent-message i {
                font-size: 2.5rem;
                color: #4CAF50;
                margin-bottom: 15px;
            }

        @@media (max-width: 768px) {
            .forgot-password-container {
                padding: 15px;
            }

            .forgot-password-card {
                padding: 30px 20px;
            }

            .back-home {
                position: relative;
                top: 0;
                left: 0;
                margin-bottom: 20px;
                display: inline-block;
            }

            .forgot-password-page {
                padding: 20px;
                align-items: flex-start;
            }
        }

        @@media (max-width: 576px) {
            .forgot-password-card {
                padding: 25px 15px;
            }

            .forgot-password-header i {
                font-size: 2.5rem;
            }

            .forgot-password-header h3 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<a asp-page="./Login" class="back-home">
    <i class="fas fa-arrow-left me-2"></i>Обратно към входа
</a>
<body>
<div class="forgot-password-container">
    <div class="forgot-password-card">
      
        <div id="step1">
            <div class="forgot-password-header">
                <i class="fas fa-key"></i>
                <h3>@ViewData["Title"]</h3>
                <p class="text-muted">Въведете вашия имейл адрес</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display: none;"></div>


            <form id="forgotPasswordForm" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Имейл адрес</label>
                    <input asp-for="Input.Email" type="email" class="form-control"
                           placeholder="name@school.bg" autocomplete="username" aria-required="true" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                    <div class="form-text">Ще изпратим линк за нулиране на паролата на този имейл.</div>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button type="submit" class="btn btn-custom">
                        <i class="fas fa-paper-plane me-2"></i>Изпрати линк
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
</body>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Show validation summary if there are errors
        document.addEventListener('DOMContentLoaded', function() {
            const validationSummary = document.querySelector('[asp-validation-summary="ModelOnly"]');
            const validationErrors = document.querySelectorAll('.text-danger');

            let hasErrors = false;
            validationErrors.forEach(error => {
                if (error.textContent.trim() !== '') {
                    hasErrors = true;
                }
            });

            if (hasErrors && validationSummary) {
                validationSummary.style.display = 'block';
            }
        });
    </script>
}
