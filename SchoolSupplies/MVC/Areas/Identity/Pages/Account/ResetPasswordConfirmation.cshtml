@page
@model ResetPasswordConfirmationModel
@{
    Layout = null;
    ViewData["Title"] = "Паролата е сменена";
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <style>
        :root {
            --primary-beige: #F5F1E8;
            --secondary-cream: #E8DFCA;
            --accent-brown: #A68B7B;
            --dark-brown: #7D6E5D;
            --light-beige: #FAF7F0;
        }

        body {
            background-color: var(--primary-beige);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            position: relative;
        }

        .back-home {
            position: fixed;
            top: 20px;
            left: 20px;
            color: var(--dark-brown);
            text-decoration: none;
            font-weight: 500;
            z-index: 100;
        }

            .back-home:hover {
                color: var(--accent-brown);
                text-decoration: none;
            }

        .confirmation-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 40px 20px;
            box-sizing: border-box;
        }

        .confirmation-container {
            width: 100%;
            max-width: 400px;
        }

        .confirmation-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px 30px;
            text-align: center;
        }

        .confirmation-icon {
            font-size: 3.5rem;
            color: #4CAF50;
            margin-bottom: 20px;
        }

        .confirmation-title {
            color: var(--dark-brown);
            margin-bottom: 15px;
            font-weight: 600;
        }

        .confirmation-message {
            color: #555;
            line-height: 1.5;
            margin-bottom: 10px;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .confirmation-card {
                padding: 30px 20px;
            }

            .confirmation-icon {
                font-size: 3rem;
            }

            .back-home {
                position: relative;
                top: 0;
                left: 0;
                margin-bottom: 20px;
                display: inline-block;
            }

            .confirmation-wrapper {
                padding-top: 60px;
            }
        }

        @@media (max-width: 576px) {
            .confirmation-card {
                padding: 25px 15px;
            }

            .confirmation-icon {
                font-size: 2.5rem;
            }

            .confirmation-title {
                font-size: 1.25rem;
            }
        }

        @@media (max-width: 400px) {
            .confirmation-card {
                padding: 20px 15px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            }

            .confirmation-icon {
                font-size: 2.2rem;
            }

            .confirmation-title {
                font-size: 1.1rem;
            }
        }
    </style>
</head>
<body>
    <a asp-page="./Login" class="back-home">
        <i class="fas fa-arrow-left me-2"></i>Обратно към входа
    </a>

    <div class="confirmation-wrapper">
        <div class="confirmation-container">
            <div class="confirmation-card">
                <div class="confirmation-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h4 class="confirmation-title">Паролата е сменена успешно!</h4>
                <!-- Ако има допълнителен текст, може да се добави тук -->
            </div>
        </div>
    </div>
</body>
</html>