@page
@model ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Нова парола";
}
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>

        .body {
            background-color: var(--primary-beige);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        :root {
            --primary-beige: #F5F1E8;
            --secondary-cream: #E8DFCA;
            --accent-brown: #A68B7B;
            --dark-brown: #7D6E5D;
            --light-beige: #FAF7F0;
        }

        .reset-password-container {
            width: 100%;
            max-width: 400px;
        }

        .reset-password-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px 30px;
        }

        .reset-password-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .reset-password-header i {
                font-size: 3rem;
                color: var(--accent-brown);
                margin-bottom: 15px;
            }

        .btn-custom {
            background-color: var(--accent-brown);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s;
            width: 100%;
        }

            .btn-custom:hover {
                background-color: var(--dark-brown);
                color: white;
                transform: translateY(-2px);
            }

        .form-control {
            padding: 12px 15px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 1rem;
        }

            .form-control:focus {
                border-color: var(--accent-brown);
                box-shadow: 0 0 0 0.25rem rgba(166, 139, 123, 0.25);
            }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: var(--dark-brown);
            text-decoration: none;
            font-weight: 500;
        }

            .back-home:hover {
                color: var(--accent-brown);
                text-decoration: none;
            }

        .form-label {
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--dark-brown);
            display: block;
        }

        .password-input-group {
            margin-bottom: 20px;
        }

        .input-with-toggle {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #777;
            cursor: pointer;
            padding: 8px;
        }

            .toggle-password:hover {
                color: var(--accent-brown);
            }

        .text-danger {
            font-size: 0.875rem;
            margin-top: 5px;
            display: block;
        }

        .alert {
            border-radius: 8px;
            margin-bottom: 20px;
        }

        /* Responsive styles */
        @@media (max-width: 768px) {
            .reset-password-container {
                padding: 15px;
            }

            .reset-password-card {
                padding: 30px 20px;
            }

            .back-home {
                position: relative;
                top: 0;
                left: 0;
                margin-bottom: 20px;
                display: inline-block;
            }

            .reset-password-page {
                padding: 20px;
                align-items: flex-start;
                padding-top: 40px;
            }
        }

        @@media (max-width: 576px) {
            .reset-password-card {
                padding: 25px 15px;
            }

            .reset-password-header i {
                font-size: 2.5rem;
            }

            .reset-password-header h3 {
                font-size: 1.5rem;
            }
        }

        @@media (max-width: 400px) {
            .reset-password-card {
                padding: 20px 15px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            }

            .btn-custom {
                padding: 10px 15px;
                font-size: 0.9rem;
            }
        }
    </style>
</head>

<a asp-page="./Login" class="back-home">
    <i class="fas fa-arrow-left me-2"></i>Обратно към входа
</a>
<body>
<div class="reset-password-container">
    <div class="reset-password-card">
        <div class="reset-password-header">
            <i class="fas fa-lock"></i>
            <h3>@ViewData["Title"]</h3>
            <p class="text-muted">Създайте нова парола за вашия профил</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"
             style="@(ViewData.ModelState.ErrorCount > 0 ? "display:block;" : "display:none;")">
        </div>

        <form id="resetPasswordForm" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="Input.Code" type="hidden" />

            <!-- Поле за имейл (скрито или само за четене) -->
            @if (Model.Input?.Email != null)
            {
                <input asp-for="Input.Email" type="hidden" />
            }
            else
            {
                <div class="password-input-group">
                    <label asp-for="Input.Email" class="form-label">Имейл</label>
                    <input asp-for="Input.Email" class="form-control"
                           autocomplete="username" aria-required="true"
                           placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
            }

            <!-- Поле за нова парола -->
            <div class="password-input-group">
                <label asp-for="Input.Password" class="form-label">Нова парола</label>
                <div class="input-with-toggle">
                    <input asp-for="Input.Password" type="password" class="form-control"
                           autocomplete="new-password" aria-required="true"
                           placeholder="Въведете нова парола" id="newPassword" />
                    <button type="button" class="toggle-password" id="toggleNewPassword">
                        <i class="far fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- Поле за потвърждение на паролата -->
            <div class="password-input-group">
                <label asp-for="Input.ConfirmPassword" class="form-label">Потвърдете новата парола</label>
                <div class="input-with-toggle">
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control"
                           autocomplete="new-password" aria-required="true"
                           placeholder="Повторете новата парола" id="confirmPassword" />
                    <button type="button" class="toggle-password" id="toggleConfirmPassword">
                        <i class="far fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-custom">
                    <i class="fas fa-save me-2"></i>Запази новата парола
                </button>
            </div>
        </form>
    </div>
</div>
</body>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Функционалност за показване/скриване на паролата
        document.addEventListener('DOMContentLoaded', function() {
            const toggleNewPassword = document.getElementById('toggleNewPassword');
            const toggleConfirmPassword = document.getElementById('toggleConfirmPassword');

            if (toggleNewPassword) {
                toggleNewPassword.addEventListener('click', function() {
                    const passwordField = document.getElementById('newPassword');
                    const icon = this.querySelector('i');

                    if (passwordField.type === 'password') {
                        passwordField.type = 'text';
                        icon.classList.remove('fa-eye');
                        icon.classList.add('fa-eye-slash');
                    } else {
                        passwordField.type = 'password';
                        icon.classList.remove('fa-eye-slash');
                        icon.classList.add('fa-eye');
                    }
                });
            }

            if (toggleConfirmPassword) {
                toggleConfirmPassword.addEventListener('click', function() {
                    const passwordField = document.getElementById('confirmPassword');
                    const icon = this.querySelector('i');

                    if (passwordField.type === 'password') {
                        passwordField.type = 'text';
                        icon.classList.remove('fa-eye');
                        icon.classList.add('fa-eye-slash');
                    } else {
                        passwordField.type = 'password';
                        icon.classList.remove('fa-eye-slash');
                        icon.classList.add('fa-eye');
                    }
                });
            }
        });
    </script>
}