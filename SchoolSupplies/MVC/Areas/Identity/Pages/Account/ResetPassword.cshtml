@page
@model ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Нова парола";
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --primary-beige: #F5F1E8;
            --secondary-cream: #E8DFCA;
            --accent-brown: #A68B7B;
            --dark-brown: #7D6E5D;
            --light-beige: #FAF7F0;
        }

        body {
            background-color: var(--primary-beige);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .reset-password-container {
            width: 100%;
            max-width: 400px;
            margin: auto;
        }

        .reset-password-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px 30px;
        }

        .reset-password-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .reset-password-header i {
                font-size: 3rem;
                color: var(--accent-brown);
                margin-bottom: 15px;
            }

        .btn-custom {
            background-color: var(--accent-brown);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s;
            width: 100%;
        }

            .btn-custom:hover {
                background-color: var(--dark-brown);
                color: white;
                transform: translateY(-2px);
            }

        .form-control {
            padding: 12px 15px;
            border-radius: 8px;
            border: 1px solid #ddd;
        }

            .form-control:focus {
                border-color: var(--accent-brown);
                box-shadow: 0 0 0 0.25rem rgba(166, 139, 123, 0.25);
            }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: var(--dark-brown);
            text-decoration: none;
            font-weight: 500;
        }

            .back-home:hover {
                color: var(--accent-brown);
            }

        .form-label {
            font-weight: 500;
            margin-bottom: 8px;
            color: var(--dark-brown);
            display: block;
        }

        .password-input-group {
            margin-bottom: 20px;
        }

        .text-danger {
            font-size: 0.875rem;
            margin-top: 5px;
            display: block;
        }

        .alert {
            border-radius: 8px;
            margin-bottom: 20px;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .reset-password-container {
                padding: 15px;
            }

            .reset-password-card {
                padding: 30px 20px;
            }

            .back-home {
                position: relative;
                top: 0;
                left: 0;
                margin-bottom: 20px;
                display: inline-block;
            }
        }

        @@media (max-width: 576px) {
            .reset-password-card {
                padding: 25px 15px;
            }

            .reset-password-header i {
                font-size: 2.5rem;
            }

            .reset-password-header h3 {
                font-size: 1.5rem;
            }
        }
    </style>
</head>
<body>
    <a asp-page="./Login" class="back-home">
        <i class="fas fa-arrow-left me-2"></i>Обратно към входа
    </a>

    <div class="reset-password-container">
        <div class="reset-password-card">
            <div class="reset-password-header">
                <i class="fas fa-lock"></i>
                <h3>@ViewData["Title"]</h3>
                <p class="text-muted">Създайте нова парола за вашия профил</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"
                 style="@(ViewData.ModelState.ErrorCount > 0 ? "display:block;" : "display:none;")">
            </div>

            <form id="resetPasswordForm" method="post">
                @Html.AntiForgeryToken()

                <input asp-for="Input.Code" type="hidden" />

                @if (Model.Input?.Email != null)
                {
                    <input asp-for="Input.Email" type="hidden" />
                }
                else
                {
                    <div class="password-input-group">
                        <label asp-for="Input.Email" class="form-label">Имейл</label>
                        <input asp-for="Input.Email" class="form-control"
                               autocomplete="username" aria-required="true"
                               placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                }

                <div class="password-input-group">
                    <label asp-for="Input.Password" class="form-label">Нова парола</label>
                    <input asp-for="Input.Password" type="password" class="form-control"
                           autocomplete="new-password" aria-required="true"
                           placeholder="Въведете нова парола" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="password-input-group">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Потвърдете новата парола</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control"
                           autocomplete="new-password" aria-required="true"
                           placeholder="Повторете новата парола" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-custom">
                        <i class="fas fa-save me-2"></i>Запази новата парола
                    </button>
                </div>
            </form>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>