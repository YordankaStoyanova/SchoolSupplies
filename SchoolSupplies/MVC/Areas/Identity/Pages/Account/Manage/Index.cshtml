<!-- Модален за добавяне на хардуер -->
<div class="modal fade" id="addHardwareModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="hardwareModalTitle">Добавяне на нов хардуер</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="hardwareForm">
                    <div class="mb-3">
                        <label class="form-label">Инвентарен номер *</label>
                        <input type="text" class="form-control" id="inventoryNumber" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Сериен номер *</label>
                        <input type="text" class="form-control" id="serialNumber" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Модел *</label>
                        <input type="text" class="form-control" id="model" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Спецификации</label>
                        <textarea class="form-control" id="specifications" rows="2" placeholder="Процесор, RAM, HDD..."></textarea>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Локация *</label>
                            <select class="form-select" id="location" required>
                                <option value="">Изберете локация</option>
                                <option value="Кабинет 209">Кабинет 209</option>
                                <option value="Кабинет 207">Кабинет 207</option>
                                <option value="Кабинет 105">Кабинет 105</option>
                                <option value="Лаборатория 3">Лаборатория 3</option>
                                <option value="Мултимедия">Мултимедия</option>
                                <option value="Сървърна">Сървърна</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Статус *</label>
                            <select class="form-select" id="status" required>
                                <option value="">Изберете статус</option>
                                <option value="Работен">Работен</option>
                                <option value="За ремонт">За ремонт</option>
                                <option value="Бракуван">Бракуван</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">История на поддръжката</label>
                        <textarea class="form-control" id="maintenanceHistory" rows="2" placeholder="Дата и описание на последна поддръжка..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Инсталиран софтуер</label>
                        <select class="form-select" id="installedSoftware" multiple>
                            <!-- Софтуерните опции ще се попълват от JavaScript -->
                        </select>
                        <small class="text-muted">Задръжте Ctrl (Windows) или Command (Mac) за избор на повече от един</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отказ</button>
                <button type="button" class="btn btn-custom" id="saveHardwareBtn">Запази</button>
            </div>
        </div>
    </div>
</div>

<!-- Модален за добавяне на софтуер -->
<div class="modal fade" id="addSoftwareModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="softwareModalTitle">Добавяне на нов софтуер</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="softwareForm">
                    <div class="mb-3">
                        <label class="form-label">Име на софтуер *</label>
                        <input type="text" class="form-control" id="softwareName" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Сериен номер *</label>
                        <input type="text" class="form-control" id="softwareSerial" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Вид *</label>
                        <select class="form-select" id="softwareType" required>
                            <option value="">Изберете вид</option>
                            <option value="Операционна система">Операционна система</option>
                            <option value="Офис пакет">Офис пакет</option>
                            <option value="Антивирус">Антивирус</option>
                            <option value="Графичен софтуер">Графичен софтуер</option>
                            <option value="Специализиран софтуер">Специализиран софтуер</option>
                            <option value="Друг">Друг</option>
                        </select>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Лиценз *</label>
                            <select class="form-select" id="licenseType" required>
                                <option value="">Изберете лиценз</option>
                                <option value="Персонален">Персонален</option>
                                <option value="Корпоративен">Корпоративен</option>
                                <option value="Образователен">Образователен</option>
                                <option value="Пробен">Пробен</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Максимална употреба *</label>
                            <input type="number" class="form-control" id="maxUsage" min="1" required>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Валидност до *</label>
                            <input type="date" class="form-control" id="validityDate" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Статус *</label>
                            <select class="form-select" id="softwareStatus" required>
                                <option value="">Изберете статус</option>
                                <option value="Активен">Активен</option>
                                <option value="Изтекъл">Изтекъл</option>
                                <option value="Изтичащ">Изтичащ</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">На компютри</label>
                        <select class="form-select" id="installedOnComputers" multiple>
                            <!-- Компютърните опции ще се попълват от JavaScript -->
                        </select>
                        <small class="text-muted">Задръжте Ctrl (Windows) или Command (Mac) за избор на повече от един</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Бележки</label>
                        <textarea class="form-control" id="softwareNotes" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отказ</button>
                <button type="button" class="btn btn-custom" id="saveSoftwareBtn">Запази</button>
            </div>
        </div>
    </div>
</div>

