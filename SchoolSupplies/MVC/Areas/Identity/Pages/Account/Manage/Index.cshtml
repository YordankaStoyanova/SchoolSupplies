                            <option value="Пробен">Пробен</option>
                            <option value="Пожизнен">Пожизнен</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Бележки</label>
                        <textarea class="form-control" id="licenseNotes" rows="2" placeholder="Допълнителна информация за лиценза..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отказ</button>
                <button type="button" class="btn btn-license" id="saveLicenseBtn">Запази лиценз</button>
