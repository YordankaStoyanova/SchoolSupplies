@using BusinessLayer
@inject SignInManager<User> SignInManager
@inject UserManager<User> userManager
@{
    var isAdmin = User.IsInRole("Administrator");
}
<!-- Табове за навигация -->
<ul class="nav nav-tabs" id="mainTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <a class="nav-link @ManageNavPages.HardwareNavClass(ViewContext)" asp-page="./Hardware" id="hardware-tab">
            <i class="fas fa-desktop me-2"></i>Хардуер
        </a>
    </li>
    <li class="nav-item" role="presentation">
        <a class="nav-link @ManageNavPages.SoftwareNavClass(ViewContext)" asp-page="./Software" id="software-tab">
            <i class="fas fa-cog me-2"></i>Софтуер
        </a>
    </li>
    @if (isAdmin)
    {
        <li class="nav-item" role="presentation">
            <a class="nav-link @ManageNavPages.AdministrationNavClass(ViewContext)" id="administration-tab" asp-page="./Administration">
                <i class="fas fa-users-cog me-2"></i>Администрация
            </a>
        </li>
    }
</ul>
