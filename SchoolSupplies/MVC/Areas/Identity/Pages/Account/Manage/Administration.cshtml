@page
@model MVC.Areas.Identity.Pages.Account.Manage.AdministrationModel
@{
    Layout = "Manage/_Layout";
    var pageNumber = Model.PageNumber;
    var totalPages = Model.TotalPages;
    var currentSearch = Request.Query["s"].ToString();
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Управление на училищен инвентар</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="row mb-4">
    <div class="col-md-12">
        <!-- Търсачка (само по име/имейл) -->
        <div class="search-filter-container mb-4">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="search-box">
                        <i class="fas fa-search"></i>
                        <form id="search">
                        <input type="text" name="s" id="s" class="form-control" placeholder="Търсене по име или имейл...">
                        </form>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <a class="btn btn-custom" asp-controller="Administration" asp-action="Create">
                        <i class="fas fa-user-plus me-2"></i>Добави потребител
                    </a>
                </div>
            </div>
        </div>

        <!-- Таблица с потребители -->
        <div class="table-container ">
            <div class="table-responsive">
                <table class="table table-custom table-hover" id="usersTable">
                    <thead>
                        <tr>
                            <th>Име</th>
                            <th>Имейл</th>
                            <th>Телефон</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.Name</td>
                                <td>@user.Email</td>
                                <td>@(user.PhoneNumber ?? "не е посочен")</td>
                                <td>
                                    <div class="action-buttons">
                                        <a class="btn-action btn-details" asp-controller="Administration" asp-action="Details" asp-route-id="@user.Id">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a class="btn-action btn-edit" asp-controller="Administration" asp-action="Edit" asp-route-id="@user.Id">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a class="btn-action btn-delete" asp-controller="Administration" asp-action="Delete" asp-route-id="@user.Id">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (totalPages > 1)
            {
                <div class="pagination-container">
                    @{
                        var prevDisabled = pageNumber <= 1 ? "disabled" : "";
                        var nextDisabled = pageNumber >= totalPages ? "disabled" : "";
                    }

                    <a class="btn btn-sm btn-outline-brown @prevDisabled"
                       asp-page="./Administration"
                       asp-route-pageNumber="@(pageNumber - 1)"
                       asp-route-s="@currentSearch">
                        <i class="fas fa-chevron-left"></i>
                    </a>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == pageNumber)
                        {
                            <button class="btn btn-sm btn-custom" disabled>@i</button>
                        }
                        else
                        {
                            <a class="btn btn-sm btn-outline-brown"
                               asp-page="./Administration"
                               asp-route-pageNumber="@i"
                               asp-route-s="@currentSearch">
                                @i
                            </a>
                        }
                    }

                    <a class="btn btn-sm btn-outline-brown @nextDisabled"
                       asp-page="./Administration"
                       asp-route-pageNumber="@(pageNumber + 1)"
                       asp-route-s="@currentSearch">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </div>
            }
        </div>

        <!-- Системна информация -->
        <div class="mt-4">
            <h5 class="category-title">Системна информация</h5>
            <div class="row">
                <div class="col-md-3">
                    <div class="license-card text-center">
                        <h6>Общо потребители</h6>
                        <div class="license-count">@Model.TotalUsers</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>
@section Scripts {
    <style>
        .badge-custom {
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
        }

        .pagination-container {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            gap: 5px;
            flex-wrap: wrap;
        }

            .pagination-container .btn {
                min-width: 40px;
            }

        .btn-outline-brown {
            color: var(--dark-brown);
            border: 1px solid var(--accent-brown);
            background-color: transparent;
            transition: all 0.3s;
        }

            .btn-outline-brown:hover:not(:disabled) {
                background-color: var(--accent-brown);
                color: white;
            }

            .btn-outline-brown:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

    </style>
    <script src="~/js/site.js" asp-append-version="true"></script>
}
