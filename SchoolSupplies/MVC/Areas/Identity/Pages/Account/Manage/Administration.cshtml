@page
@model MVC.Areas.Identity.Pages.Account.Manage.AdministrationModel
@{
    Layout = "Manage/_Layout";
}
<div class="tab-pane fade show active" id="administration" role="tabpanel">
    <div class="row">
        <div class="col-md-12">
            <div class="search-filter-container mb-4">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <form id="search">
                                <input type="text" name="s" id="s" class="form-control" placeholder="Търсене по име или имейл...">
                            </form>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-custom w-100" data-bs-toggle="modal" data-bs-target="#addUserModal">
                            <i class="fas fa-user-plus me-2"></i>Добави
                        </button>
                    </div>
                </div>
            </div>

            <div class="table-container">
                <div class="table-responsive">
                    <table class="table table-custom table-hover">
                        <thead>
                            <tr>
                                <th>Име</th>
                                <th>Имейл</th>
                                <th>Tелефонен номер</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody">
                            @foreach (var item in Model.Users)
                            {
                                <tr>
                                    <td><strong>@item.Name</strong></td>
                                    <td>@item.Email</td>
                                    <td>@item.PhoneNumber </td>
                                    <td>
                                        <div class="action-buttons">
                                            <button class="btn-action btn-details">
                                                <i class="fas fa-eye"></i>
                                            </button>
                                            <button class="btn-action btn-edit" onclick="editUser(${item.id})">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn-action btn-delete" onclick="deleteUser(${item.id})">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-4">
                <h5 class="category-title">Системна информация</h5>
                <div class="row">
                    <div class="col-md-3">
                        <div class="license-card text-center">
                            <h6>Общо потребители</h6>
                            <div class="license-count" id="totalUsersCount">@Model.Users.Count</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

