@page
@using BusinessLayer.Enum
@model MVC.Areas.Identity.Pages.Account.Manage.SoftwareModel
@{
    Layout = "Manage/_Layout";

}
<div class="tab-pane fade show active" id="software" role="tabpanel">
    <div class="row mb-4">
        <!-- Лицензи -->
        <div class="col-md-4">
            <h3 class="category-title">Налични лицензи</h3>
            <div id="licenseCardsContainer">
                <!-- Лицензните карти ще се попълват от JavaScript -->
            </div>
        </div>

        <!-- Таблица със софтуер -->
        <div class="col-md-8">
            <div class="search-filter-container">
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <form id="search">
                                <input type="text" name="s" id="s" class="form-control" placeholder="Търсене по име на софтуер...">
                            </form>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="t">
                            @{
                                <option selected value="all">Всички видове</option>
                                foreach (var item in Model.Softwares?.Select(s => s.Type)?.Distinct())
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <div class="double-buttons">
                            @if (User.IsInRole("Administrator"))
                             {
                            <a class="btn btn-custom" asp-action="Create" asp-controller="Software">
                                <i class="fas fa-plus me-2"></i>Добави софтуер
                            </a>
                            <a class="btn btn-license" asp-action="Create" asp-controller="License">
                                <i class="fas fa-key me-2"></i>Добави лиценз
                            </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-container section-fixed-height">
                <div class="table-responsive">
                    <table class="table table-custom table-hover">
                        <thead>
                            <tr>
                                <th>Име</th>
                                <th>Сериен №</th>
                                <th>Вид</th>
                                <th>Лиценз</th>
                                <th>Валидност</th>
                                <th>На компютри</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="softwareTableBody">

                            @foreach (var item in Model.Softwares)
                            {
                                var statusName = "";
                                var statusBadge = "";

                                if (item.License.ExpirationDate > DateTime.Now)
                                {
                                    statusName = "Активен";
                                    statusBadge = "bg-success";
                                }
                                else
                                {
                                    statusName = "Изтекъл";
                                    statusBadge = "bg-danger";
                                }
                            

                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.SerialNumber</td>
                                <td>@item.Type?.Name</td>
                                <td>@item.License?.Name</td>
                                <td>@item.License?.ExpirationDate </td>
                                <td>@string.Join(", ", item.Hardwares.Take(2).Select(h => h.Name).ToList()) @(item.Hardwares?.Count > 2 ? "и още" : "")</td>
                                <td>
                                    <span class="badge @statusBadge ">@statusName</span>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <a class="btn-action btn-details" asp-action="Details" asp-route-id="@item.Id" asp-controller="Software">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    @if (User.IsInRole("Administrator"))
                                            {
                                                <a class="btn-action btn-edit" asp-action="Edit" asp-route-id="@item.Id" asp-controller="Software">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a class="btn-action btn-delete" asp-action="Delete" asp-route-id="@item.Id" asp-controller="Software">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            }
                                        </div>
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
@section Scripts {
        <script src="~/js/site.js" asp-append-version="true"></script>
}
