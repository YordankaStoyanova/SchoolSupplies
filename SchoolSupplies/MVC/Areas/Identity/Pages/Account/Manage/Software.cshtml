@page
@using BusinessLayer.Enum
@model MVC.Areas.Identity.Pages.Account.Manage.SoftwareModel
@{
    Layout = "Manage/_Layout";
    Layout = "Manage/_Layout";
    var pageNumber = Model.PageNumber;
    var totalPages = Model.TotalPages;

    var currentSearch = Request.Query["s"].ToString();
    var currentType = Request.Query["t"].ToString();

}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Управление на училищен инвентар</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="tab-pane fade show active" id="software" role="tabpanel">
    <div class="row mb-4">
        <!-- Лицензи -->
        <div class="col-md-4">
            <h3 class="category-title">Налични лицензи</h3>

            <div id="licenseCardsContainer">

                @foreach (var stat in Model.LicenseStats)
                {
                    <div class="license-card">

                        <h5>
                            <i class="fas fa-cog me-2"></i>@stat.Title
                        </h5>

                        <div class="license-count">
                            @stat.TotalLicenses
                        </div>

                        <p class="text-center">лиценза</p>

                        <p class="text-muted small mt-2">
                            @stat.UsedLicenses използвани
                        </p>

                    </div>
                }

            </div>
        </div>

        <!-- Таблица със софтуер -->
        <div class="col-md-8">
            <div class="search-filter-container">
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <form id="search">
                                <input type="text" name="s" id="s" class="form-control" placeholder="Търсене по име на софтуер...">
                            </form>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="t">
                            @{
                                <option selected value="all">Всички видове</option>
                                foreach (var item in Model.Softwares?.Select(s => s.Type)?.Distinct())
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <div class="double-buttons">
                            @if (User.IsInRole("Administrator"))
                             {
                            <a class="btn btn-custom-software" asp-action="Create" asp-controller="Software">
                                <i class="fas fa-plus me-2"></i>Добави софтуер
                            </a>
                                <a class="btn btn-license" asp-controller="Software" asp-action="License">
                                    <i class="fas fa-key me-2"></i> Добави лиценз
                                </a>
                         
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="table-container ">
                <div class="table-responsive">
                    <table class="table table-custom table-hover">
                        <thead>
                            <tr>
                                <th>Име</th>
                                <th>Сериен №</th>
                                <th>Вид</th>
                                <th>Лиценз</th>
                                <th>Валидност</th>
                                <th>На компютри</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="softwareTableBody">

                            @foreach (var item in Model.Softwares)
                            {
                                var statusName = "";
                                var statusBadge = "";

                                if (item.License.ExpirationDate > DateTime.Now)
                                {
                                    statusName = "Активен";
                                    statusBadge = "bg-success";
                                }
                                else
                                {
                                    statusName = "Изтекъл";
                                    statusBadge = "bg-danger";
                                }
                            

                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.SerialNumber</td>
                                <td>@item.Type?.Name</td>
                                <td>@item.License?.Name</td>
                                <td>@item.License?.ExpirationDate </td>
                                    <td>
                                    @string.Join(", ", item.Hardwares.Take(2).Select(h => h.Name).ToList()) @(item.Hardwares?.Count > 2 ? "и още" : "" )</td>
                                <td>
                                    <span class="badge @statusBadge ">@statusName</span>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <a class="btn-action btn-details" asp-action="Details" asp-route-id="@item.Id" asp-controller="Software">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    @if (User.IsInRole("Administrator"))
                                            {
                                                <a class="btn-action btn-edit" asp-action="Edit" asp-route-id="@item.Id" asp-controller="Software">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a class="btn-action btn-delete" asp-action="Delete" asp-route-id="@item.Id" asp-controller="Software">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            }
                                        </div>
                                </td>
                            </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (totalPages > 1)
                {
                    <div class="pagination-container">
                        @{
                            var prevDisabled = pageNumber <= 1 ? "disabled" : "";
                            var nextDisabled = pageNumber >= totalPages ? "disabled" : "";
                        }

                        <a class="btn btn-sm btn-outline-brown @prevDisabled"
                           asp-page="./Software"
                           asp-route-pageNumber="@(pageNumber - 1)"
                           asp-route-s="@currentSearch"
                           asp-route-t="@currentType">
                            <i class="fas fa-chevron-left"></i>
                        </a>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            if (i == pageNumber)
                            {
                                <button class="btn btn-sm btn-custom" disabled>@i</button>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-outline-brown"
                                   asp-page="./Software"
                                   asp-route-pageNumber="@i"
                                   asp-route-s="@currentSearch"
                                   asp-route-t="@currentType">
                                    @i
                                </a>
                            }
                        }

                        <a class="btn btn-sm btn-outline-brown @nextDisabled"
                           asp-page="./Software"
                           asp-route-pageNumber="@(pageNumber + 1)"
                           asp-route-s="@currentSearch"
                           asp-route-t="@currentType">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>
    </body>
    </html>
@section Scripts {
    <style>
            .pagination-container {
                margin-top: 20px;
                display: flex;
                justify-content: center;
                gap: 5px;
                flex-wrap: wrap;
            }

                .pagination-container .btn {
                    min-width: 40px;
                }

            .btn-outline-brown {
                color: var(--dark-brown);
                border: 1px solid var(--accent-brown);
                background-color: transparent;
                transition: all 0.3s;
            }

                .btn-outline-brown:hover:not(:disabled) {
                    background-color: var(--accent-brown);
                    color: white;
                }

                .btn-outline-brown:disabled {
                    opacity: 0.5;
                    cursor: not-allowed;
                }

        .btn-custom-software {
            background-color: var(--accent-brown);
            color: white;
            border: none;
            padding: 10px 20px;
            margin-bottom : 5px;
            border-radius: 6px;
            font-weight: 500;
            transition: all 0.3s;
        }

        .btn-custom-software:hover {
            background-color: var(--dark-brown);
            color: white;
            transform: translateY(-2px);
        }

    </style>
        <script src="~/js/site.js" asp-append-version="true"></script>
}
