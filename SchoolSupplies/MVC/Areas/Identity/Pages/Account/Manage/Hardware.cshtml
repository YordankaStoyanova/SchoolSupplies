@page
@using BusinessLayer.Enum
@model MVC.Areas.Identity.Pages.Account.Manage.HardwareModel
@{
    Layout = "Manage/_Layout";
    var pageNumber = Model.PageNumber;
    var totalPages = Model.TotalPages;

    var currentSearch = Request.Query["s"].ToString();
    var currentStatus = Request.Query["t"].ToString();
    var currentRoom = Request.Query["r"].ToString();
   
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]Управление на училищен инвентар</title>
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<!-- ХАРДУЕР -->
<div class="tab-pane fade show active" id="hardware" role="tabpanel">
    <div class="row mb-4">
        <!-- Статистика за статуси -->
        <div class="col-md-4">
            <h3 class="category-title">Статус на оборудването</h3>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <div class="status-card status-working">
                        <h4><i class="fas fa-check-circle me-2"></i>Работещи</h4>
                        <h2 id="workingCount">@Model.WorkingCount</h2>
                        <p>устройства</p>
                    </div>
                </div>
                <div class="col-md-12 mb-3">
                    <div class="status-card status-repair">
                        <h4><i class="fas fa-tools me-2"></i>За ремонт</h4>
                        <h2 id="repairCount">@Model.RepairCount</h2>
                        <p>устройства</p>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="status-card status-scrapped">
                        <h4><i class="fas fa-ban me-2"></i>Бракувани</h4>
                        <h2 id="scrappedCount">@Model.ScrappedCount</h2>
                        <p>устройства</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Таблица с устройства -->
        <div class="col-md-8">
            <div class="search-filter-container">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="search-box">
                            <i class="fas fa-search"></i>
                            <form id="search">
                                <input type="text" name="s" id="s" class="form-control" placeholder="Търсене по име.......">
                            </form>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <select class="form-select" id="t">
                            @{
                                var type = ViewContext.RouteData.Values["t"]?.ToString();

                                <option value="all">Всички статуси</option>
                                <option value="@ItemStatus.Working">Работещ</option>
                                <option value="@ItemStatus.Repair">За ремонт</option>
                                <option value="@ItemStatus.Disposed">Бракуван</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3">

                        <select class="form-select" id="r">

                            <option value="all">Всички стаи</option>
                            @foreach (var item in Model.Rooms)
                            {
                                <option value="@item.Id">@item.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        @if (User.IsInRole("Administrator"))
                        {
                        <a class="btn btn-custom w-100" asp-action="Create" asp-controller="Hardware">
                            <i class="fas fa-plus me-2"></i>Добави
                        </a>
                        }
                    </div>
                </div>
            </div>

            <div class="table-container ">
                <div class="table-responsive">
                    <table class="table table-custom table-hover">
                        <thead>
                            <tr>
                                <th>Инв. №</th>
                                <th>Сериен №</th>
                                <th>Име</th>
                                <th>Вид</th>
                                <th>Локация</th>
                                <th>Статус</th>
                                <th>История на поддръжката</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody id="hardwareTableBody">
                            @foreach (var item in Model.Hardwares)
                            {
                                var statusName = "";
                                var statusBadge = "";
                            
                                switch (item.Status)
                                {
                                    case BusinessLayer.Enum.ItemStatus.Working:
                                        statusName = "Работещ";
                                        statusBadge = "badge-working";
                                        break;
                                    case BusinessLayer.Enum.ItemStatus.Repair:
                                        statusName = "За ремонт";
                                        statusBadge = "badge-repair";
                                        break;
                                    case BusinessLayer.Enum.ItemStatus.Disposed:
                                        statusName = "Бракуван";
                                        statusBadge = "badge-scrapped";
                                        break;
                                }
                                <tr>
                                    <td><strong>@item.InventoryNumber</strong></td>
                                    <td>@item.SerialNumber</td>
                                    <td>@item.Name</td>
                                    <td>@item.Type.Name</td>

                                    <td>@item.Room.Name</td>
                                    <td>
                                        <span class="badge-custom @statusBadge">
                                            @statusName
                                        </span>
                                    </td>
                                    <td>
                                        @{
                                            var log = item.MaintenanceLogs.FirstOrDefault();
                                            var label = log is null ? "Няма" : $"{log.Date} {log.Description}";
                                        }
                                        <small>@label</small>
                                    </td>
                                    <td>
                                        <div class="action-buttons">

                                            <a class="btn-action btn-details" asp-action="Details" asp-controller="Hardware" asp-route-id="@item.Id">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (User.IsInRole("Administrator"))
                                            {
                                                <a class="btn-action btn-edit" asp-action="Edit" asp-controller="Hardware" asp-route-id="@item.Id">
                                                    <i class="fas fa-edit"></i>
                                                </a>

                                                <a class="btn-action btn-delete" asp-action="Delete" asp-controller="Hardware" asp-route-id="@item.Id">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (totalPages > 1)
                {
                    <div class="pagination-container">
                        @{
                            var prevDisabled = pageNumber <= 1 ? "disabled" : "";
                            var nextDisabled = pageNumber >= totalPages ? "disabled" : "";
                        }

                        <a class="btn btn-sm btn-outline-brown @prevDisabled"
                           asp-page="./Hardware"
                           asp-route-pageNumber="@(pageNumber - 1)"
                           asp-route-s="@currentSearch"
                           asp-route-t="@currentStatus"
                           asp-route-r="@currentRoom">
                            <i class="fas fa-chevron-left"></i>
                        </a>

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            if (i == pageNumber)
                            {
                                <button class="btn btn-sm btn-custom" disabled>@i</button>
                            }
                            else
                            {
                                <a class="btn btn-sm btn-outline-brown"
                                   asp-page="./Hardware"
                                   asp-route-pageNumber="@i"
                                   asp-route-s="@currentSearch"
                                   asp-route-t="@currentStatus"
                                   asp-route-r="@currentRoom">
                                    @i
                                </a>
                            }
                        }

                        <a class="btn btn-sm btn-outline-brown @nextDisabled"
                           asp-page="./Hardware"
                           asp-route-pageNumber="@(pageNumber + 1)"
                           asp-route-s="@currentSearch"
                           asp-route-t="@currentStatus"
                           asp-route-r="@currentRoom">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </div>
                }


            </div>
        </div>
    </div>
</div>
</body>
</html>
@section Scripts{
    <style>
        .badge-custom {
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
        }

        .pagination-container {
            margin-top: 20px;
            display: flex;
            justify-content: center;
            gap: 5px;
            flex-wrap: wrap;
        }

            .pagination-container .btn {
                min-width: 40px;
            }

        .btn-outline-brown {
            color: var(--dark-brown);
            border: 1px solid var(--accent-brown);
            background-color: transparent;
            transition: all 0.3s;
        }

            .btn-outline-brown:hover:not(:disabled) {
                background-color: var(--accent-brown);
                color: white;
            }

            .btn-outline-brown:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }
       @@media (max-width: 915px) {
            .search-filter-container .row > div:last-child

        {
            flex: 0 0 100% !important;
            max-width: 100% !important;
            margin-top: 10px !important;
        }

        }
    </style>
    <script src="~/js/site.js" asp-append-version="true"></script>
}