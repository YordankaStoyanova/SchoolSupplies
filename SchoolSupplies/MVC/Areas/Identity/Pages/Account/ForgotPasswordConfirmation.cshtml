@page
@model ForgotPasswordConfirmation
@{
    Layout = null;
    ViewData["Title"] = "Линкът е изпратен";
}
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        .body{
            background-color: var(--primary-beige);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        :root {
            --primary-beige: #F5F1E8;
            --secondary-cream: #E8DFCA;
            --accent-brown: #A68B7B;
            --dark-brown: #7D6E5D;
            --light-beige: #FAF7F0;
        }

        .forgot-password-container {
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }

        .forgot-password-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px 30px;
        }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: var(--dark-brown);
            text-decoration: none;
            font-weight: 500;
            z-index: 10;
        }

            .back-home:hover {
                color: var(--accent-brown);
                text-decoration: none;
            }

        .email-sent-message {
            text-align: center;
            padding: 20px;
        }

            .email-sent-message i {
                font-size: 3.5rem;
                color: #4CAF50;
                margin-bottom: 20px;
            }

            .email-sent-message h5 {
                color: var(--dark-brown);
                margin-bottom: 15px;
                font-weight: 600;
            }

            .email-sent-message p {
                color: #555;
                line-height: 1.5;
                margin-bottom: 10px;
            }

        .text-muted {
            color: #777 !important;
            font-size: 0.9rem;
        }

        /* Responsive стилове */
        @@media (max-width: 768px) {
            .forgot-password-container {
                padding: 15px;
            }

            .forgot-password-card {
                padding: 30px 20px;
            }

            .back-home {
                position: relative;
                top: 0;
                left: 0;
                margin-bottom: 20px;
                display: inline-block;
            }

            .forgot-password-confirmation-page {
                padding: 20px;
                align-items: flex-start;
                padding-top: 40px;
            }
        }

        @@media (max-width: 576px) {
            .forgot-password-card {
                padding: 25px 15px;
            }

            .email-sent-message i {
                font-size: 3rem;
            }

            .email-sent-message h5 {
                font-size: 1.25rem;
            }
        }

        @@media (max-width: 400px) {
            .forgot-password-card {
                padding: 20px 15px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            }

            .email-sent-message {
                padding: 15px 10px;
            }

                .email-sent-message i {
                    font-size: 2.5rem;
                    margin-bottom: 15px;
                }
        }
    </style>
    </head>

<a asp-page="./Login" class="back-home">
    <i class="fas fa-sign-in-alt me-2"></i>Към вход
</a>
<body>
<div class="forgot-password-container">
    <div class="forgot-password-card">
        <!-- Стъпка 2: Потвърждение (Единствено съдържание) -->
        <div class="email-sent-message">
            <i class="fas fa-check-circle"></i>
            <h5>@ViewData["Title"]</h5>
            <p>Изпратихме линк за смяна на парола на посочения имейл адрес.</p>
            <p class="text-muted small">Моля, проверете вашата пощенска кутия.</p>
        </div>
        <!-- Няма повече бутони или форми тук -->
    </div>
</div>
</body>

