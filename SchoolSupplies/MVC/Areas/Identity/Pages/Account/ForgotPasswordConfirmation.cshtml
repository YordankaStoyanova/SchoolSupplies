@page
@model ForgotPasswordConfirmation
@{
    Layout = null;
    ViewData["Title"] = "Линкът е изпратен";
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        :root {
            --primary-beige: #F5F1E8;
            --secondary-cream: #E8DFCA;
            --accent-brown: #A68B7B;
            --dark-brown: #7D6E5D;
            --light-beige: #FAF7F0;
        }

        body {
            background-color: var(--primary-beige);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
        }

        .forgot-password-container {
            width: 100%;
            max-width: 400px;
            margin: auto;
        }

        .forgot-password-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px 30px;
        }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: var(--dark-brown);
            text-decoration: none;
            font-weight: 500;
        }

            .back-home:hover {
                color: var(--accent-brown);
            }

        .email-sent-message {
            text-align: center;
            padding: 20px;
        }

            .email-sent-message i {
                font-size: 3.5rem;
                color: #4CAF50;
                margin-bottom: 20px;
            }

            .email-sent-message h5 {
                color: var(--dark-brown);
                margin-bottom: 15px;
                font-weight: 600;
            }

            .email-sent-message p {
                color: #555;
                line-height: 1.5;
                margin-bottom: 10px;
            }

        .text-muted {
            color: #777 !important;
            font-size: 0.9rem;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .forgot-password-container {
                padding: 15px;
            }

            .forgot-password-card {
                padding: 30px 20px;
            }

            .back-home {
                position: relative;
                top: 0;
                left: 0;
                margin-bottom: 20px;
                display: inline-block;
            }
        }

        @@media (max-width: 576px) {
            .forgot-password-card {
                padding: 25px 15px;
            }

            .email-sent-message i {
                font-size: 3rem;
            }
        }
    </style>
</head>
<body>
    <a asp-page="./Login" class="back-home">
        <i class="fas fa-sign-in-alt me-2"></i>Към вход
    </a>

    <div class="forgot-password-container">
        <div class="forgot-password-card">
            <div class="email-sent-message">
                <i class="fas fa-check-circle"></i>
                <h5>@ViewData["Title"]</h5>
                <p>Изпратихме линк за смяна на парола на посочения имейл адрес.</p>
                <p class="text-muted small">Моля, проверете вашата пощенска кутия.</p>
            </div>
        </div>
    </div>
</body>
</html>