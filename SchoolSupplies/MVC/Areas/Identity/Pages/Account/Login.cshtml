@page
@model LoginModel

@{
    Layout = null;
    ViewData["Title"] = "Вход в системата";
}
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/school.ico" rel="shortcut icon" type="image/x-icon" />
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            --primary-beige: #F5F1E8;
            --secondary-cream: #E8DFCA;
            --accent-brown: #A68B7B;
            --dark-brown: #7D6E5D;
            --light-beige: #FAF7F0;
        }

        body {
            background-color: var(--primary-beige);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 0;
        }

        .login-container {
            width: 100%;
            max-width: 400px;
            padding: 20px;
        }

        .login-card {
            background-color: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px 30px;
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .login-header i {
                font-size: 3rem;
                color: var(--accent-brown);
                margin-bottom: 15px;
            }

            .login-header h3 {
                color: var(--dark-brown);
                font-weight: 600;
                margin-bottom: 10px;
            }

            .login-header p {
                color: #666;
                font-size: 14px;
            }

        .btn-custom {
            background-color: var(--accent-brown);
            color: white;
            border: none;
            padding: 12px 20px;
            border-radius: 8px;
            font-weight: 500;
            transition: all 0.3s;
            width: 100%;
        }

            .btn-custom:hover {
                background-color: var(--dark-brown);
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(166, 139, 123, 0.3);
            }

        .form-control {
            padding: 12px 15px;
            border-radius: 8px;
            border: 1px solid #ddd;
            font-size: 16px;
        }

            .form-control:focus {
                border-color: var(--accent-brown);
                box-shadow: 0 0 0 0.25rem rgba(166, 139, 123, 0.25);
            }

        .form-label {
            font-weight: 600;
            color: var(--dark-brown);
            margin-bottom: 8px;
            font-size: 14px;
        }

        .back-home {
            position: absolute;
            top: 20px;
            left: 20px;
            color: var(--dark-brown);
            text-decoration: none;
            font-weight: 500;
            font-size: 16px;
            z-index: 1000;
        }

            .back-home:hover {
                color: var(--accent-brown);
                text-decoration: none;
            }

        .alert {
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 20px;
            font-size: 14px;
            border: none;
        }

        .alert-danger {
            background-color: #f8d7da;
            border-color: #f5c6cb;
            color: #721c24;
        }

        .password-change-link {
            color: var(--accent-brown);
            text-decoration: none;
            font-size: 0.9rem;
            cursor: pointer;
            display: inline-block;
            margin: 5px 0;
        }

            .password-change-link:hover {
                color: var(--dark-brown);
                text-decoration: underline;
            }

        .text-danger {
            color: #dc3545;
            font-size: 12px;
            margin-top: 5px;
            display: block;
        }

        .form-check-input:checked {
            background-color: var(--accent-brown);
            border-color: var(--accent-brown);
        }

        .form-check-label {
            color: var(--dark-brown);
            font-size: 14px;
        }

        .text-center p {
            margin-bottom: 10px;
        }

            .text-center p:last-child {
                margin-bottom: 0;
            }

        .text-muted {
            color: #666 !important;
        }
 
        /* Responsive design */
        @@media (max-width: 576px) {
            .login-container

        {
            padding: 15px;
        }

        .login-card {
            padding: 30px 20px;
        }

        .login-header i {
            font-size: 2.5rem;
        }

        .back-home {
            top: 15px;
            left: 15px;
            font-size: 14px;
        }

        body {
            padding-top: 60px;
        }

        }

        @@media (max-width: 400px) {
            .login-card

        {
            padding: 25px 15px;
        }

        .btn-custom, .form-control {
            padding: 10px 12px;
            font-size: 14px;
        }

        }  
    </style>
</head>

<a href="~/" class="back-home">
    <i class="fas fa-arrow-left me-2"></i>Начало
</a>
<body>

<div class="login-container">
    <div class="login-card">
        <div class="login-header">
            <i class="fas fa-school"></i>
            <h3>@ViewData["Title"]</h3>
            <p class="text-muted">Моля, въведете вашите данни</p>
        </div>

        <!--Съобщение за валидационни грешки -->
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

        <form id="account" method="post">
                <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Имейл адрес</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username"
                       aria-required="true" placeholder="name@school.bg" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

                <div class=" mb-3">
                        <label asp-for="Input.Password" class="form-label">Парола</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                       aria-required="true" placeholder="Въведете паролата си" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">
                    Запомни ме
                </label>
            </div>

            <div class="d-grid gap-2 mb-3">
                <button id="login-submit" type="submit" class="btn btn-custom">
                    <i class="fas fa-sign-in-alt me-2"></i>Вход
                </button>
            </div>

            <div class="text-center">
                <p>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="password-change-link">
                        Забравена парола?
                    </a>
                </p>
            </div>
        </form>
    </div>
</div>

</body>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
          
            const submitButton = document.getElementById('login-submit');
            if (submitButton) {
                const form = document.getElementById('account');
                form.addEventListener('submit', function() {
                    submitButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Влизане...';
                    submitButton.disabled = true;
                });
            }
        });
    </script>
}